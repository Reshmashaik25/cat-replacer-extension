{
  "manifest_version": 3,
  "name": "Cat Replacer",
  "version": "1.0",
  "description": "Replaces all images on a webpage with random cat images.",
  "permissions": [
  "scripting",
  "activeTab"
],
"host_permissions": [
  "https://api.thecatapi.com/*"
],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}